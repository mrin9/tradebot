{
    "$jsonSchema": {
        "bsonType": "object",
        "description": "Definition of a trading strategy rule for the TradeFlow engine",
        "required": [
            "ruleId",
            "name",
            "category",
            "goal",
            "enabled",
            "applicableTo",
            "timeframe",
            "indicators",
            "entry",
            "exit"
        ],
        "properties": {
            "ruleId": {
                "bsonType": "string",
                "description": "Unique identifier for the strategy rule (e.g., 'ema-5x21+rsi-14')"
            },
            "name": {
                "bsonType": "string",
                "description": "Human-readable name of the strategy"
            },
            "category": {
                "bsonType": "string",
                "enum": [
                    "TREND",
                    "MEAN_REVERSION",
                    "BREAKOUT",
                    "SCALP",
                    "VOLATILITY"
                ],
                "description": "Category of the strategy"
            },
            "goal": {
                "bsonType": "string",
                "description": "Short description of the strategy's goal"
            },
            "explanation": {
                "bsonType": "string",
                "description": "Detailed explanation of the strategy logic, typically in Markdown format"
            },
            "enabled": {
                "bsonType": "bool",
                "description": "Whether the strategy is currently enabled and active for the engine to pick up"
            },
            "applicableTo": {
                "bsonType": "array",
                "items": {
                    "bsonType": "string",
                    "enum": [
                        "NIFTY",
                        "BANKNIFTY",
                        "FINNIFTY",
                        "SENSEX",
                        "MIDCPNIFTY"
                    ]
                },
                "description": "List of underlying instruments this strategy applies to"
            },
            "timeframe": {
                "bsonType": "int",
                "description": "Base timeframe in seconds (e.g., 60 for 1-minute, 300 for 5-minute candles)"
            },
            "indicators": {
                "bsonType": "array",
                "description": "List of indicators required by the strategy",
                "items": {
                    "bsonType": "object",
                    "required": [
                        "indicatorId",
                        "displayLabel",
                        "type",
                        "params",
                        "InstrumentType"
                    ],
                    "properties": {
                        "indicatorId": {
                            "bsonType": "string",
                            "description": "Internal ID for the indicator used in entry/exit conditions (e.g., 'fast_ema')"
                        },
                        "displayLabel": {
                            "bsonType": "string",
                            "description": "Display name of the indicator for UI presentation"
                        },
                        "type": {
                            "bsonType": "string",
                            "enum": [
                                "EMA",
                                "SMA",
                                "RSI",
                                "MACD",
                                "SUPERTREND",
                                "ATR",
                                "BOLLINGER",
                                "VWAP"
                            ],
                            "description": "Type of the technical indicator to calculate"
                        },
                        "params": {
                            "bsonType": "object",
                            "description": "Parameters dictionary for the indicator calculation (e.g., {'period': 14})"
                        },
                        "InstrumentType": {
                            "bsonType": "string",
                            "enum": [
                                "SPOT",
                                "CE",
                                "PE",
                                "OPTIONS_BOTH",
                                "FUTURES"
                            ],
                            "description": "The category of instrument feed this indicator relies on"
                        }
                    }
                }
            },
            "entry": {
                "bsonType": "object",
                "description": "Entry conditions and configurations",
                "required": [
                    "operator",
                    "conditions"
                ],
                "properties": {
                    "intent": {
                        "bsonType": "string",
                        "enum": [
                            "LONG",
                            "SHORT",
                            "AUTO"
                        ],
                        "description": "Directional intent of the setup. AUTO determines it automatically based on condition matching."
                    },
                    "evaluateSpot": {
                        "bsonType": "bool",
                        "description": "Whether to also apply the conditions against the underlying spot chart"
                    },
                    "evaluateInverse": {
                        "bsonType": "bool",
                        "description": "Whether to also apply the conditions against the opposite option chart"
                    },
                    "operator": {
                        "bsonType": "string",
                        "enum": [
                            "AND",
                            "OR"
                        ],
                        "description": "Logical operator combining all conditions"
                    },
                    "signals": {
                        "bsonType": "object",
                        "description": "Map representing signals emitted based on matched conditions"
                    },
                    "conditions": {
                        "bsonType": "array",
                        "description": "List of execution conditions (e.g., crossovers or thresholds)",
                        "items": {
                            "bsonType": "object",
                            "required": [
                                "type"
                            ],
                            "properties": {
                                "type": {
                                    "bsonType": "string",
                                    "enum": [
                                        "crossover",
                                        "crossunder",
                                        "threshold",
                                        "slope",
                                        "direction_match"
                                    ],
                                    "description": "The condition type to evaluate"
                                },
                                "indicatorId": {
                                    "bsonType": "string",
                                    "description": "The indicator ID to evaluate. Required for threshold, slope, direction_match."
                                },
                                "fastIndicatorId": {
                                    "bsonType": "string",
                                    "description": "The 'fast' indicator ID in a crossover/crossunder scenario."
                                },
                                "slowIndicatorId": {
                                    "bsonType": "string",
                                    "description": "The 'slow' indicator ID in a crossover/crossunder scenario."
                                },
                                "op": {
                                    "bsonType": "string",
                                    "enum": [
                                        ">",
                                        "<",
                                        ">=",
                                        "<=",
                                        "==",
                                        "!="
                                    ],
                                    "description": "The mathematical operator to apply for threshold/direction matches."
                                },
                                "value": {
                                    "bsonType": [
                                        "double",
                                        "int"
                                    ],
                                    "description": "The static numerical value to compare against."
                                },
                                "valueIndicatorId": {
                                    "bsonType": "string",
                                    "description": "The dynamic indicator ID to compare the 'indicatorId' against."
                                }
                            }
                        }
                    }
                }
            },
            "exit": {
                "bsonType": "object",
                "description": "Exit conditions and configurations using the same structure as entry",
                "required": [
                    "operator",
                    "conditions"
                ],
                "properties": {
                    "evaluateSpot": {
                        "bsonType": "bool"
                    },
                    "evaluateInverse": {
                        "bsonType": "bool"
                    },
                    "operator": {
                        "bsonType": "string",
                        "enum": [
                            "AND",
                            "OR"
                        ]
                    },
                    "conditions": {
                        "bsonType": "array",
                        "items": {
                            "bsonType": "object",
                            "required": [
                                "type"
                            ]
                        }
                    }
                }
            },
            "restrictions": {
                "bsonType": "object",
                "description": "Operational restrictions like time windows or trade limits",
                "properties": {
                    "avoidWindows": {
                        "bsonType": "array",
                        "description": "Time windows when the strategy should not execute trades",
                        "items": {
                            "bsonType": "object",
                            "required": [
                                "from",
                                "to",
                                "tz"
                            ],
                            "properties": {
                                "from": {
                                    "bsonType": "string",
                                    "description": "Start time in HH:MM format"
                                },
                                "to": {
                                    "bsonType": "string",
                                    "description": "End time in HH:MM format"
                                },
                                "tz": {
                                    "bsonType": "string",
                                    "description": "Timezone for the window (e.g., 'Asia/Kolkata')"
                                }
                            }
                        }
                    },
                    "maxTradesPerDay": {
                        "bsonType": "int",
                        "description": "Maximum number of allowed trades per day to prevent overtrading"
                    }
                }
            }
        }
    }
}